{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ui-sensei.local/schemas/pattern.schema.json",
  "title": "Reusable Pattern",
  "type": "object",
  "required": [
    "pattern_name",
    "category",
    "description",
    "observed_on",
    "transferability",
    "implementation_cost",
    "ux_value",
    "a11y_risk",
    "performance_risk",
    "rules",
    "implementation_notes",
    "avoid_when"
  ],
  "properties": {
    "pattern_name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "layout",
        "typography",
        "component",
        "motion",
        "copy",
        "rendering",
        "accessibility",
        "performance"
      ]
    },
    "description": {
      "type": "string"
    },
    "observed_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "applies_to": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "transferability": {
      "type": "string",
      "enum": [
        "universal",
        "contextual",
        "brand-specific"
      ]
    },
    "implementation_cost": {
      "type": "string",
      "enum": [
        "easy",
        "medium",
        "hard",
        "expensive"
      ]
    },
    "ux_value": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "a11y_risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "performance_risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "evidence_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "avoid_when": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
